#!/bin/bash
set -e

case "$1" in
    remove)
        # Keep user, data, and config for potential reinstall
        echo "PatchPanel removed but user and data preserved"
        ;;
    purge)
        # Remove everything including user and data
        echo "Purging PatchPanel completely..."
        
        # Remove system user
        if getent passwd patchpanel > /dev/null 2>&1; then
            deluser patchpanel || true
        fi
        
        # Remove data directories (user confirmation should happen via apt/dpkg)
        rm -rf /var/lib/patchpanel
        rm -rf /var/log/patchpanel
        rm -rf /etc/patchpanel
        
        echo "PatchPanel completely removed"
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Do nothing for these cases
        ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

# Reload systemd daemon
systemctl daemon-reload || true

#DEBHELPER#
